{
  "name": "synnova",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "concurrently -n vite,convex -c blue,yellow \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\" \"convex dev\"",
    "dev:frontend": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
    "dev:convex": "convex dev",
    "build": "vite build && mkdir -p .output/server && cp instrument.server.mjs .output/server",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "seed:initial-setup": "tsx tools/scripts/convex/seed_initial_setup.ts",
    "seed:conjunto": "tsx tools/scripts/convex/seed_conjunto.ts",
    "email:dev": "email dev -d ./convex/email/templates -p 3001",
    "prepare": "husky",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "changelog:all": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.65",
    "@base-ui/react": "^1.4.1",
    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "0.1.0",
    "@fontsource-variable/roboto": "^5.2.10",
    "@phosphor-icons/react": "^2.1.10",
    "@react-email/components": "^1.0.12",
    "@sentry/tanstackstart-react": "^10.48.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-form-devtools": "^0.2.20",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "^8.21.3",
    "@uploadthing/react": "^7.3.3",
    "@workos/authkit-tanstack-react-start": "^0.5.0",
    "ai": "^6.0.182",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.116",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "nitro": "3.0.260311-beta",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@edge-runtime/vm": "^5.0.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@types/node": "^22.10.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "conventional-changelog-cli": "^5.0.0",
    "convex-test": "^0.0.51",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react-email": "^5.2.10",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "unrs-resolver"
    ]
  }
}
